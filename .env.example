# === LLM (Ollama) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_EMBEDDING_MODEL=
LLM_TEMPERATURE=0.0

# === Database (PostgreSQL + pgvector) ===
DATABASE_URL=
PGVECTOR_TABLE_NAME=pdf_documents
PGVECTOR_COLLECTION_NAME=pdf_documents

# === Document Processing ===
PDF_PATH=document.pdf
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
ENABLE_OCR=1

# === Retrieval ===
RETRIEVAL_TOP_K=20